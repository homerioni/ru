generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

enum ROLE {
  USER
  ADMIN
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  username      String?
  image         String?
  accounts      Account[]
  sessions      Session[]
  role          ROLE      @default(USER)
  clubAdminId   Int?

  @@map("users")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Club {
  id      Int     @id @default(autoincrement())
  name    String  @unique
  logoSrc String
  isShow  Boolean @default(true)

  tournirs MatchType[]

  homeMatches Match[] @relation("HomeClubMatches")
  awayMatches Match[] @relation("AwayClubMatches")

  players Player[]

  transfersFrom Transfer[] @relation("TransferFromClub")
  transfersTo Transfer[] @relation("TransferToClub")

  createdAt DateTime @default(now())
  updateAt  DateTime @updatedAt
}

enum PLAYER_TYPE {
  player
  old_player
  team
}

enum AWARD_TYPE {
  match
  month
  year
}

model Award {
  id         String @id @default(cuid())
  type       AWARD_TYPE
  clubImgSrc String
  clubName   String
  matchType  String?
  matchName  String?

  player   Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
  playerId Int

  createdAt DateTime @default(now())
  updateAt  DateTime @updatedAt
}

model Player {
  id        Int     @id @default(autoincrement())
  name      String
  type      PLAYER_TYPE @default(player)
  photo     String?
  position  String
  number    Int?
  isShow    Boolean
  username  String?
  telegram  String?
  instagram String?
  vk        String?
  tiktok    String?
  youtube   String?

  club   Club @relation(fields: [clubId], references: [id])
  clubId Int

  playedIn MatchPlayer[]

  transfers Transfer[]

  awards Award[]

  createdAt DateTime @default(now())
  updateAt  DateTime @updatedAt
}

model MatchVote {
  id       String @id @default(cuid())
  username String
  playerId Int

  match   Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  matchId Int

  createdAt DateTime @default(now())
  updateAt  DateTime @updatedAt
}

enum VOTE_STATUS {
  init
  started
  closed
}

model Match {
  id          Int         @id @default(autoincrement())
  date        DateTime
  score       Int[]       @default([])
  round       Int?
  yellowCards Int?        @default(0)
  redCards    Int?        @default(0)
  voteStatus  VOTE_STATUS @default(init)

  players MatchPlayer[]

  votes MatchVote[]

  type   MatchType @relation(fields: [typeId], references: [id])
  typeId Int

  homeClub   Club @relation("HomeClubMatches", fields: [homeClubId], references: [id])
  homeClubId Int

  awayClub   Club @relation("AwayClubMatches", fields: [awayClubId], references: [id])
  awayClubId Int

  createdAt DateTime @default(now())
  updateAt  DateTime @updatedAt
}

enum MatchPlayerClub {
  homeClub
  awayClub
}

model MatchPlayer {
  id           Int @id @default(autoincrement())
  goals        Int @default(0)
  assists      Int @default(0)
  playerNumber Int?
  club         MatchPlayerClub

  match   Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  matchId Int

  player   Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
  playerId Int

  @@unique([matchId, playerId])
}

enum MatchTypes {
  cup
  league
  any
}

model MatchType {
  id        Int     @id @default(autoincrement())
  type      MatchTypes @default(any)
  name      String
  fullName  String
  year      Int?
  isArchive Boolean @default(false)

  clubs   Club[]
  matches Match[]
}

model Transfer {
  id          Int @id @default(autoincrement())
  date        DateTime
  clubAdminId Int?

  player   Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
  playerId Int

  fromClub   Club? @relation("TransferFromClub", fields: [fromClubId], references: [id])
  fromClubId Int?

  toClub   Club? @relation("TransferToClub", fields: [toClubId], references: [id])
  toClubId Int?

  createdAt DateTime @default(now())
  updateAt  DateTime @updatedAt
}
